{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "electron"],
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["./dist"]
}
