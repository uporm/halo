{
  "private": true,
  "author": "扫地僧 <horse.devops@gmail.com>",
  "main": "electron/dist/index.js",
  "scripts": {
    "dev:renderer": "umi dev",
    "dev:main": "tsc -p electron/tsconfig.json -w",
    "dev:electron": "wait-on http://localhost:8000 && cross-env NODE_ENV=development electron --no-sandbox ./electron/dist/index.js",
    "dev": "concurrently -k \"yarn dev:renderer\" \"yarn dev:main\" \"yarn dev:electron\"",
    "build:renderer": "umi build",
    "build:main": "tsc -p electron/tsconfig.json",
    "build": "yarn build:renderer && yarn build:main && electron-builder",
    "postinstall": "umi setup",
    "setup": "umi setup",
    "start": "yarn dev"
  },
  "dependencies": {
    "@ant-design/x": "^2.7.0",
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "antd": "^6.4.3",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "umi": "^4.6.57",
    "valtio": "^2.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "package.json"
    ]
  },
  "packageManager": "yarn@4.15.0+sha512.07ec708ac11e2eaa4ea2b04cfbb272812f7e74a753f1595eaef4486c663a98306a30cca3e6fc40f7a0b168dcfb3a2490b6a5e0501e20fb69cc36f563dd161c53"
}
